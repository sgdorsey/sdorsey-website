.site-title-link{color:inherit;text-decoration:none}h1{font-family:playfair display,serif;font-size:45px;line-height:1.2;margin-bottom:.1rem;margin-top:0}h2{font-family:playfair display,serif;font-size:35px;line-height:1.2;margin-bottom:.5rem;margin-top:0}h3{font-family:roboto condensed,sans-serif;font-size:25px}.page-title{font-size:25px}.blog-title{font-size:20px}.site-subtitle{margin-top:0;font-family:roboto condensed,sans-serif;font-optical-sizing:auto;font-style:normal}body{font-family:roboto condensed,sans-serif;max-width:800px;margin:2rem auto;padding:0 1rem;line-height:1.6}nav{margin-bottom:2rem}nav a{margin-right:1rem}.header{background-color:#f4eee3}.nav{background-color:#5c0000}.nav .nav-link{color:#fff;font-family:roboto condensed,sans-serif}.btn{background-color:#5c0000;border-color:#000;font-family:roboto condensed,sans-serif}.profile-pic{width:220px;height:220px;object-fit:cover;object-position:center 20%;border-radius:50%}